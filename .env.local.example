# -------------------------------------------------------
# Copy this file to .env.local and fill in your values
# Supabase: https://supabase.com → your project → Settings → API
# Anthropic: https://console.anthropic.com
# -------------------------------------------------------

# Supabase — public keys (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase — service role key (SERVER ONLY — never expose to browser)
# Used for the shared plan page (/plan/[token]) to bypass RLS for unauthenticated viewers
# Found at: Supabase dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic — used for meal plan generation, swapping, and recipe import
ANTHROPIC_API_KEY=sk-ant-api03-...
